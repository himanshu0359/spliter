# Splitr Environment Variables
# Clone this to .env.local and fill in your values

# Clerk (get from dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_DOMAIN=your-clerk-domain
CLERK_APP_ID=your-app-id

# Convex (after npx convex deploy)
CONVEX_URL=https://your-deployment.convex.site
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.site

# Inngest (inngest.com dashboard)
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# Resend (resend.com, optional)
RESEND_API_KEY=your-resend-key

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
